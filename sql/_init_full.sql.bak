-- ===== FORUM POSTS (target='forum' or 'admin') =====
INSERT INTO forum_posts (author_id, target, content, created_at) VALUES
(45, 'forum', 'Anyone know why the forum has a weird restriction? I can''t find where to message admin directly.', '2026-04-20 09:15:00'),
(46, 'forum', 'Yeah I saw that too. It says something about account age. Kinda annoying honestly.', '2026-04-21 10:30:00'),
(47, 'forum', 'Read through the policy. Only managers whose accounts are older than 1 year can message admin directly. It''s a security measure.', '2026-04-22 14:00:00'),
(45, 'forum', 'A whole year? I''ve only been here since October. Guess I''m stuck posting here like everyone else.', '2026-04-24 11:45:00'),
(7, 'forum', 'Same boat. Since September and still can''t. I wonder if it''s actually enforced or just a bluff? Anyone tried?', '2026-04-28 09:00:00'),
(46, 'forum', 'Anyone know a good spot for lunch around here? Cafeteria is getting old.', '2026-05-01 12:15:00'),
(49, 'forum', 'I just started this week so I''m useless for food tips. But I heard there''s a ramen place nearby?', '2026-05-02 08:30:00'),
(47, 'forum', 'There''s an Italian place two blocks east on Maple. Only been there once but it was solid.', '2026-05-03 13:00:00'),
(48, 'forum', 'Wait we have a cafeteria? I''ve been here 3 months and never found it lmao', '2026-05-04 10:00:00'),
(45, 'forum', 'Basement level. Took me 2 months to discover it. Don''t blame you.', '2026-05-05 09:45:00'),
(47, 'forum', 'The bathroom situation though. Mine is literally on the other side of the building. I time my coffee intake now.', '2026-05-07 11:00:00'),
(7, 'forum', 'Third floor here and the nearest restroom is by the east stairwell. Solid 5 minute round trip.', '2026-05-08 14:30:00'),
(46, 'forum', 'At least you guys have offices. I''m in a cubicle on floor 1. Hello open space.', '2026-05-09 10:15:00'),
(49, 'forum', 'Cubicle gang represent. First day they sat me next to the photocopier.', '2026-05-10 09:00:00'),
(48, 'forum', 'I think you need a year of tenure to get an office. Or know someone. I''m still waiting.', '2026-05-12 11:30:00'),
(45, 'forum', 'Has anyone actually met the admin in person? Like face to face?', '2026-05-14 08:45:00'),
(46, 'forum', 'Nope. 7 months and I''ve never seen him. Pretty sure he works remote exclusively.', '2026-05-15 10:00:00'),
(47, 'forum', 'I saw someone in a suit walk into the corner office once. Could''ve been him? No clue.', '2026-05-16 14:00:00'),
(7, 'forum', 'The coffee machine on floor 2 is broken again. That''s the third time this month.', '2026-05-18 07:30:00'),
(49, 'forum', 'It''s been broken since day one and I''m on day 5 lmao. Welcome to SecureBank I guess.', '2026-05-18 08:15:00'),
(48, 'forum', 'Submitted a maintenance ticket for it two weeks ago. Radio silence.', '2026-05-19 09:00:00'),
(45, 'forum', 'Getting lost in this building should be an Olympic sport. I GPS to the meeting rooms.', '2026-05-21 11:00:00'),
(46, 'forum', 'I just follow the signs. Eventually you get somewhere recognizable.', '2026-05-22 10:30:00'),
(47, 'forum', 'Parking is a nightmare. I''ve been parking in visitor for a month. Anyone got a spare spot?', '2026-05-25 08:00:00'),
(7, 'forum', 'Took 6 months but my badge finally works on the third floor door. Progress!', '2026-06-02 09:30:00'),
(2, 'forum', '4 year anniversary today! Stopping by office 324 if anyone wants pizza and drinks. First come first served!', '2026-06-20 11:00:00'),
(3, 'forum', 'Congrats John! I''ll swing by during lunch. 4 years is no joke in this industry.', '2026-06-20 12:15:00'),
(45, 'forum', 'Congrats John! Quick question - you can message admin right? Since you''re one of the old guard?', '2026-06-20 13:00:00'),
(2, 'forum', 'Thanks Robert! And yes the vets have that privilege. There''s a private channel on the forum for us. It''s been a policy since before most of you joined.', '2026-06-20 14:00:00'),
(7, 'forum', 'So there IS a way. Good to know. One day I''ll get there. 9 months to go I think.', '2026-06-20 15:30:00'),
(3, 'forum', '2 years here now! Different company than when I started honestly. All the system changes...', '2026-06-25 10:00:00'),
(44, 'forum', 'Happy 2 year Sarah! I''m at 2.5 myself. Time flies when you''re buried in paperwork.', '2026-06-27 14:00:00'),
(43, 'forum', '3 years here. Seen five different versions of the transaction portal. Still has the same bugs lol.', '2026-06-30 11:30:00'),
(45, 'forum', 'Wait the transaction portal has known bugs? I thought it was just me doing something wrong.', '2026-07-02 09:00:00'),
(2, 'forum', 'Oh it''s not you Robert. Let''s just say some things have been broken since years before you joined. We''ve learned to work around it.', '2026-07-05 16:00:00'),
(44, 'forum', '2.5 years officially. Honestly the first year is the hardest. After that you know all the quirks.', '2026-07-10 10:00:00'),
(47, 'forum', 'Any advice for surviving year one without going crazy?', '2026-07-12 09:30:00'),
(2, 'forum', 'Learn the system make friends with IT and don''t bother admin unless you really need to. The private channel is there for a reason.', '2026-07-14 11:00:00'),
(3, 'forum', 'What John said. And yeah that private admin channel? Totally worth being patient for. It''s handy.', '2026-07-16 14:00:00'),
(43, 'forum', '3 years and never needed to message admin myself. But nice to know the option is there.', '2026-07-18 09:00:00'),
(46, 'forum', 'Finally figured out the printer on the second floor. Only took me 8 months.', '2026-07-25 10:30:00'),
(49, 'forum', 'I got upgraded to an office! Only took 4 months but hey window view!', '2026-07-28 11:00:00'),
(48, 'forum', 'Fire alarm went off today and nobody knew where to evacuate to. We just stood in the parking lot.', '2026-07-30 14:00:00'),
(7, 'forum', 'Wait there was a fire drill? I was in a meeting and completely missed the announcement.', '2026-08-01 09:15:00'),
(45, 'forum', 'Quarterly reports are due and the system keeps timing out on me. Anyone else?', '2026-08-05 10:00:00'),
(44, 'forum', 'Happens every quarter without fail. Give it a few hours it''ll stabilize. Standard SecureBank.', '2026-08-05 15:00:00'),
(2, 'forum', 'End of quarter crunch. Seen this 16 times now. You get used to it.', '2026-08-06 09:00:00'),
(47, 'forum', 'So the veterans are saying this chaos is normal? Great. Good to know it''s not just me.', '2026-08-10 11:30:00'),
(3, 'forum', 'Completely normal. By your second year you''ll be expecting it and planning around it.', '2026-08-12 10:00:00'),
(43, 'forum', 'Enjoy the madness newbies. It''s part of the SecureBank experience. Wouldn''t change it though.', '2026-08-15 14:00:00');

